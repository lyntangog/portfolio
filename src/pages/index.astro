---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Timeline from '../components/Timeline.astro';
import TimelineItem from '../components/TimelineItem.astro';
import Footer from '../components/Footer.astro';
import FolderLinks from '../components/FolderLinks.astro';
import StatCard from "../components/StatCard.astro";
---



<Layout title="Gwendolyn Tangog">
  <Nav />
  <Hero /> 
  <FolderLinks />

 <Section id="highlights" eyebrow="00 / " title="Highlights">
<div style="display: flex; justify-content: center;">
  <div style="width: 350px;">
    <StatCard value="190" label="People Reached" accent="#3e2f24" />
  </div>
</div>
<p> Through my own initiatives and my collaborations, I have been able to work towards my passion of helping others and making a positive impact in my community!</p>
</Section>

  <Section id="education" eyebrow="01 / " title="Education">
    <Timeline>
      <TimelineItem date="2028" title="International Baccalaureate" org="Southville International School and Colleges" toggleLabel="Courses and Details">
        <p>This journey is currently in progress.</p>
        <p>HL:</p>
        <p>Chemistry, Biology, Psychology</p>
        <p>SL:</p>
        <p>Math AA, English Lang & Lit, Spanish Ab Initio</p>
      </TimelineItem>
      <TimelineItem date="2026" title="K-10 Basic Education" org="Southville International School and Colleges" toggleLabel="Details">
        <p>Top 30 students in the year</p>
      </TimelineItem>
    </Timeline>
  </Section>

  <Section id="experience" eyebrow="02 / " title="Experience">
    <Timeline>
      <TimelineItem date="July 2026 - present" title="General Member" org="Neurosphere"
      skills={['Research', 'Digital Design']}>
        <p> I create informative digital booklets on topics related to neuroscience and psychology.
        </p>
      </TimelineItem>
        <TimelineItem date="July 2026 - present" title="Summer Research Cohort" org="Little Hearts Foundation" location="Greater Toronto Area, Canada"
      skills={['Remote', 'Research', 'Communication', 'Collaboration']}>
        <p> The mission is to create an informational manual on medical related topics/concerns accessible for all but directed to pediatrics.
        </p>
      </TimelineItem>
        <TimelineItem date="July 2026 - present" title="SEVAH Pediatric Neuroinclusion Fellowship" org="Sevah Neuro" location="CA, United States"
      skills={['Remote', 'Research', 'Communication', 'Collaboration']}>
        <p> Interact with neuroimpaired children and work on a neurscience/pediatric related research paper. </p>
      </TimelineItem>
       <TimelineItem date="June 2026 - present" title="Marketing and Outreach Intern" org="Empathy in Medicine Initiative" location="NY, United States"
      skills={['Remote','Digital Design', 'Communication', 'Research']}>
        <p>I create marketing materials (eg. informational posts) and draft/connect for outreach opportunities </p>
      </TimelineItem>
      <TimelineItem date="July 2026" title="Volunteer" org="Mind4Youth" location="CA, United States"
      skills={['Asynchronous','Design']}>
        <p>I created cards for children in hospitals and studied lessons and modules centered around psychology provided</p>
      </TimelineItem>
    </Timeline>
  </Section>

  <Section id="leadership" eyebrow="03 /" title="Leadership">
    <p>
      Leadership experiences I have had through highschool
    </p>
    <Timeline>
      <TimelineItem date="2025- present" title="Core Secretary" org="The Kindness Project" location="Southville International School and Colleges"
      highlights={['Co-Founder']}
      skills={['Facilitator', 'Tutor', 'Psychology', 'Advocacy']}
      toggleLabel="About">
        <p>
         The Kindness Project aims to promote kindness and empathy in the school. We focus on mental health and have three divisions. </p>
        <p>Kindness Campaign: Focus on advocacy for mental health awareness and support.</p>
        <p>Peer Mentors': Provides support to the studednt body through Peer Tutoring for academics and Facilitating for mental health.</p>
        <p>Psychology Society: Organizes discussions on psychology topics such as disorders and concepts.</p>
      </TimelineItem>
      <TimelineItem date="2025 – present" title="Research Head" org="Red Cross Youth" location="Southville International School and Colleges"
      skills={['Research', 'Advocacy']}
      toggleLabel="About">
        <p>
        Gathered information and researched on the events of natural disasters happening in the Philippines and special days regarding the environment to be posted onto our Red Cross Youths social media account.
        </p>
      </TimelineItem>
    </Timeline>
  </Section>

  <Section id="initiative" eyebrow="04 /" title="Initiatives">
    <p>Initiatives and projects I have created or assisted in </p>
    <Timeline>
      <TimelineItem date="Created 2025" title="Kindness Playshop" org="The Kindness Project"
      highlights={['Project Lead and Creator']}
      >
        <p>I created a yearly workshop for preschool students to promote kindness, empathy, managing emotions for themselves and how it affects others.</p>
      </TimelineItem>
      <TimelineItem date="May 2026" title="Healthy Minds, Clean Hands" org="Collaborative Self Project">
        <p>Hosted a workshop with informal settlers aged 13 and below on how to take care of themselves mentally and physically during natural disasters and hygiene as it was a frequent occurance at that time.</p>
        <p>I self curated my own hygiene kits and gave it to the kids as a token after the workshop.</p>
      </TimelineItem>
      <TimelineItem date="February 2026" title="First-aid Seminar" org="Red Cross Youth > Southville International School and Colleges">
        <p>Assisted in a first-aid seminar in International Baccalaureate in collaboration with their club. We helped the students learn basic bandaging techniques and what to do when in risk of rabies.</p>
      </TimelineItem>
    </Timeline>
  </Section>

  <Section id="awards" eyebrow="05 /" title="Awards">
    <details class="year-group" open>
      <summary class="year-toggle">
        <span class="year-label">Academic Year 2025–2026</span>
        <span class="year-chevron" aria-hidden="true">▾</span>
      </summary>

      <Timeline>
        <TimelineItem title="TOEFL" award={['Perfect Scorer']}>
        </TimelineItem>
        <TimelineItem title="International Psychology Olympiad" award={['Regional Top 6 Philippines']}>
          <p> Highest Distinction, Final Round Qualifier</p>
          <p> Final Round is not yet completed </p>
        </TimelineItem>
        <TimelineItem title="Thailand International Biology and Medical Olympiad Challenge Final Round" award={['Gold Medalist']}>
          <p>Top Scorer</p>
        </TimelineItem>
        <TimelineItem title="Hong Kong International Science Olympiad Final Round" award={['Gold Medalist']}>
        </TimelineItem>
        <TimelineItem title="Thailand International Biology and Medical Olympiad Challenge Regional Round" award={['Gold Medalist']}>
        </TimelineItem>
        <TimelineItem title="Hong Kong International Science Olympiad Heat Round" award={['Gold Medalist']}>
        </TimelineItem>
        <TimelineItem title="International Earth Science Olympiad" award={['Gold Medalist']}>
        </TimelineItem>
        <TimelineItem title="World Scholar's Cup Manila Round" award={['Silver Medalist']}>
          <p>Silver Medals: Debate, Scholars' Bowl, Team Debate</p>
        </TimelineItem>
        <TimelineItem title="Philippine International Math and Science Olympiad" award={['Bronze Medalist']}>
        </TimelineItem>
        <TimelineItem title="Asian Science and Mathematics Olympiad" award={['Bronze Medalist']}>
        </TimelineItem>
      </Timeline>
    </details>

    <details class="year-group">
      <summary class="year-toggle">
        <span class="year-label">Academic Year 2024–2025</span>
        <span class="year-chevron" aria-hidden="true">▾</span>
      </summary>

      <Timeline>
        <TimelineItem title="World Scholars Cup Manila Round" award={['Gold Medalist']}>
          <p>Gold Medals: Creative Writing, Team Writing</p>
        </TimelineItem>
        <TimelineItem title="International Brilliant Minds Olympiad" award={['Silver Medalist']}>
          <p>English</p>
        </TimelineItem>
      </Timeline>
    </details>
  </Section>

  <Footer />
</Layout>

<style>
  .year-group {
    border-bottom: 1px solid var(--grey-300, #c7d2dd);
    margin-bottom: 8px;

    .stat-card {
  max-width: 420px;
  margin: 0 auto;
  padding: 44px 32px;
  border-radius: 32px;
  background: #f5f6ee;
  border: 3px solid #f5f6ee;
  text-align: center;
  box-shadow: 8px 8px 0 rgba(111, 168, 118, 0.18);
}

.stat-number {
  font-family: var(--font-display);
  font-size: clamp(3rem, 8vw, 4.5rem);
  font-weight: 700;
  color: var(--brown-deep);
  margin: 0 0 8px;
  line-height: 1;
}

.stat-label {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--ink);
  opacity: 0.75;
  margin: 0;
  max-width: 260px;
  margin-inline: auto;
}
  }

  .year-toggle {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 4px;
    font-family: var(--font-display, Georgia, serif);
    font-size: 1.1rem;
    color: var(--ink, #233244);
    user-select: none;
  }

  .year-toggle::-webkit-details-marker {
    display: none;
  }

  .year-chevron {
    transition: transform 0.2s ease;
    font-size: 0.9rem;
  }

  details[open] .year-chevron {
    transform: rotate(180deg);
  }

  .year-toggle:hover .year-label {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  details > :global(*:not(summary)) {
    padding-top: 4px;
    padding-bottom: 12px;
  }
</style>

