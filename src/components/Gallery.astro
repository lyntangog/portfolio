---
// Gallery.astro
// A "coverflow" style carousel: the current image is large and centered,
// with neighboring images shown smaller on either side
// (…small, medium, CURRENT, medium, small…).
// Click any thumbnail to bring it to the center.
//
// Usage:
// ---
// import Gallery from '../components/Gallery.astro';
// const images = [
//   { src: '/images/project-1.jpg', alt: 'Project One hero shot', caption: 'Project One' },
//   { src: '/images/project-2.jpg', alt: 'Project Two detail view' },
// ];
// ---
// <Gallery images={images} />

export interface GalleryImage {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  images: GalleryImage[];
  /** Unique id, useful if you render more than one Gallery on a page. */
  id?: string;
  /** Which image starts centered (0-indexed). */
  startIndex?: number;
}

const {
  images,
  id = `gallery-${Math.random().toString(36).slice(2, 9)}`,
  startIndex = 0,
} = Astro.props;
---

<div class="carousel" id={id} data-start={startIndex+2}>

  <div class="carousel-track">
    {images.map((image, i) => (
      <button
        class="carousel-item"
        type="button"
        data-index={i}
        aria-label={image.caption ?? image.alt}
      >
        <img src={image.src} alt={image.alt} loading={i === startIndex ? 'eager' : 'lazy'} decoding="async" />
      </button>
    ))}

  </div>

  <p class="carousel-caption"></p>

  <div class ="button-container">
  <button class="carousel-btn prev" type="button" aria-label="Previous image">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <button class="carousel-btn next" type="button" aria-label="Next image" >
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  </div>

</div>

<style>
  .button-container {
    display: flex;
    gap: 30px;
  }
  .carousel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  .carousel-track {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 80%;
    height: clamp(140px, 30vw, 320px);
    perspective: 1000px;
  }

  .carousel-item {
    position: relative;
    flex: 0 0 auto;
    border: none;
    padding: 0;
    margin: 0;
    background: #111;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    height: 55%;
    aspect-ratio: 4 / 3;
    opacity: 0;
    transform: scale(0.8);
    filter: brightness(0.6);
    transition: height 0.35s ease, opacity 0.35s ease, transform 0.35s ease, filter 0.35s ease;

    /* Hidden by default; JS assigns one of the classes below to reveal. */
    position: absolute;
  }

  .carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Distance-from-center states, applied by the client script */
  .carousel-item.is-current {
    position: relative;
    height: 100%;
    opacity: 1;
    transform: scale(1);
    filter: brightness(1);
    z-index: 5;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .carousel-item.is-medium {
    position: relative;
    height: 72%;
    opacity: 0.85;
    transform: scale(1);
    filter: brightness(0.75);
    z-index: 4;
  }

  .carousel-item.is-small {
    position: relative;
    height: 50%;
    opacity: 0.6;
    transform: scale(1);
    filter: brightness(0.55);
    z-index: 3;
  }

  .carousel-item:hover {
    filter: brightness(1);
  }

  .carousel-btn {
    flex: 0 0 auto;
    display: inline-block;
    place-items: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: #eee;
    color: #333;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .carousel-btn:hover {
    background: #ddd;
  }

  .carousel-btn:active {
    transform: scale(0.92);
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .carousel-caption {
    margin: 0;
    font-size: 1.2rem;
    color: #444;
    text-align: center;
    min-height: 1.2em;
  }

  @media (max-width: 480px) {
    .carousel-btn {
      width: 34px;
      height: 34px;
    }
  }
</style>

<script>
  interface GalleryImage {
    caption?: string;
  }

  class Carousel {
    root: HTMLElement;
    items: HTMLElement[];
    captionEl: HTMLElement;
    index: number;

    // How many neighbors on each side get "medium" treatment before
    // falling back to "small". Anything beyond VISIBLE_RANGE is hidden.
    static MEDIUM_RANGE = 1;
    static VISIBLE_RANGE = 2;

    constructor(root: HTMLElement) {
      this.root = root;
      this.items = Array.from(root.querySelectorAll('.carousel-item'));
      this.captionEl = root.querySelector('.carousel-caption')!;
      this.index = Number(root.dataset.start) || 0;

      this.items.forEach((item) => {
        item.addEventListener('click', () => {
          this.go(Number(item.dataset.index));
        });
      });

      root.querySelector('.carousel-btn.next')!.addEventListener('click', () => this.go(this.index + 1));
      root.querySelector('.carousel-btn.prev')!.addEventListener('click', () => this.go(this.index - 1));

      this.render();
    }

    go(i: number) {
      const count = this.items.length;
      this.index = (i + count) % count;
      this.render();
    }

    render() {
      const count = this.items.length;

      this.items.forEach((item, i) => {
        item.classList.remove('is-current', 'is-medium', 'is-small');

        // Shortest distance around the loop (so it wraps both directions).
        let dist = Math.abs(i - this.index);
        dist = Math.min(dist, count - dist);

        if (dist === 0) {
          item.classList.add('is-current');
        } else if (dist <= Carousel.MEDIUM_RANGE) {
          item.classList.add('is-medium');
        } else if (dist <= Carousel.VISIBLE_RANGE) {
          item.classList.add('is-small');
        }
        // dist beyond VISIBLE_RANGE: no class added, stays hidden (opacity 0, position: absolute)
      });

      const img = this.items[this.index].querySelector('img')!;
      this.captionEl.textContent = img.alt || '';
    }
  }

  document.querySelectorAll<HTMLElement>('.carousel').forEach((el) => new Carousel(el));
</script>
