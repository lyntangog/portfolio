---
interface Props {
  date: string;
  title: string;
  org?: string;
}
const { date, title, org } = Astro.props;
---

<article class="item">
  <span class="node" aria-hidden="true"></span>
  <p class="date">{date}</p>
  <h3>{title}</h3>
  {org && <p class="org">{org}</p>}
  <div class="body">
    <slot />
  </div>
</article>

<style>
  .item {
    position: relative;
    margin-bottom: 34px;
  }
  .item:last-child {
    margin-bottom: 0;
  }
  .node {
    position: absolute;
    left: -28px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    background: var(--bg-panel);
    border: 2px solid var(--blue);
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue);
    margin: 0 0 4px;
  }
  h3 {
    font-size: 1.05rem;
    margin: 0 0 2px;
  }
  .org {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    opacity: 0.7;
    margin: 0 0 10px;
  }
  .body {
    font-size: 0.95rem;
  }
  .body :global(p) {
    margin: 0 0 10px;
  }
  .body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
