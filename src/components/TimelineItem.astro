---

type Highlight = string | { label: string; href: string };

interface Props {
  date?: string;
  title: string;
  org?: string;
  toggleLabel?: string;
  badges?: string[];
  highlights?: Highlight[];   // ← was string[]
  skills?: string[];
  location?: string;
  award?: string[];
}

const { date, title, org, toggleLabel = 'More info', badges, highlights, skills, location, award } = Astro.props;
const hasBody = Astro.slots.has('default');
---

<article class="item">
  <span class="node" aria-hidden="true"></span>
  {date && <p class="date">{date}</p>}
  <h3>{title}</h3>
  {org && <p class="org">{org}</p>}
  {location && <p class="location">{location}</p>}
  {award && award.length > 0 && <p class="award">{award.join(', ')}</p>}

  {badges && badges.length > 0 && (
    <ul class="badges">
      {badges.map((b) => <li class="badge">{b}</li>)}
    </ul>
  )}

  {highlights && highlights.length > 0 && (
  <ul class="badges highlights">
    {highlights.map((h) => (
      <li class="badge highlight">
        {typeof h === 'string'
          ? h
          : <a href={h.href} target="_blank" rel="noopener noreferrer" class="hl-link">{h.label}</a>
        }
      </li>
    ))}
  </ul>
)}

  {skills && skills.length > 0 && (
    <ul class="skills">
      {skills.map((s) => <li class="skill">{s}</li>)}
    </ul>
  )}

  {hasBody && (
    <details class="dropdown">
      <summary class="toggle">
        <span>{toggleLabel}</span>
        <svg class="chevron" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <div class="body">
        <slot />
      </div>
    </details>
  )}
</article>

<style>
  .item {
    position: relative;
    margin-bottom: 34px;
  }
  .item:last-child {
    margin-bottom: 0;
  }
  .node {
    position: absolute;
    left: -28px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 3px;
    background: var(--bg-panel);
    border: 2px solid var(--blue);
  }
  .date {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue);
    margin: 0 0 4px;
  }
  h3 {
    font-size: 1.05rem;
    margin: 0 0 2px;
  }
  .org {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    opacity: 0.7;
    margin: 0 0 10px;
  }
  .location {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    opacity: 0.7;
    margin: -10px 0 10px;
  }
  .award {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--ink);
    opacity: 0.7;
    margin: 0 0 10px;
  }

  /* --- shared pill list ------------------------------------------------ */
  .badges,
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0 0 8px;
    padding: 0;
  }

  /* outlined — used for GPA-style badges and highlights */
  .badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--blue);
    border: 1px solid var(--blue);
    border-radius: 999px;
    padding: 2px 10px;
    opacity: 0.85;
  }

  /* highlights get a faint background tint to stand out from plain badges */
  .highlight {
    background: color-mix(in srgb, var(--blue) 10%, transparent);
  }

  .hl-link {
  color: inherit;
  text-decoration: none;
  }
  .hl-link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* filled — neutral, doesn't compete with highlights */
  .skill {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink);
    background: rgba(0, 0, 0, 0.06);
    border-radius: 999px;
    padding: 2px 10px;
    opacity: 0.8;
  }

  /* --- dropdown -------------------------------------------------------- */
  .dropdown {
    margin-top: 4px;
  }
  .toggle {
    display: flex;
    align-items: center;
    gap: 5px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue);
    user-select: none;
    width: fit-content;
  }
  .toggle::-webkit-details-marker { display: none; }
  .toggle::marker                 { display: none; }
  .toggle:hover { opacity: 0.75; }

  .chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }
  details[open]:not(.is-closing) .chevron {
    transform: rotate(180deg);
  }

  .body {
    font-size: 0.95rem;
    padding-top: 8px;
    animation: slideDown 0.25s ease;
  }
  details.is-closing .body {
    animation: slideUp 0.25s ease forwards;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-6px); }
  }

  .body :global(p) { margin: 0 0 10px; }
  .body :global(p:last-child) { margin-bottom: 0; }
</style>

<script>
  document.querySelectorAll<HTMLDetailsElement>('details.dropdown').forEach((details) => {
    const summary = details.querySelector<HTMLElement>('summary')!;
    const body    = details.querySelector<HTMLElement>('.body')!;

    summary.addEventListener('click', (e) => {
      if (!details.open) return;

      e.preventDefault();
      details.classList.add('is-closing');
      body.addEventListener('animationend', () => {
        details.removeAttribute('open');
        details.classList.remove('is-closing');
      }, { once: true });
    });
  });
</script>