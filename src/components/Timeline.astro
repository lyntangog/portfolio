<div class="timeline">
  <slot />
</div>

<style>
  .timeline {
    position: relative;
    padding-left: 28px;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background-image: linear-gradient(var(--blue-pale) 60%, transparent 0%);
    background-size: 2px 8px;
    background-repeat: repeat-y;
  }
</style>
